{
  "name": "helia-remote-pinning",
  "version": "0.0.0",
  "description": "How to pin content to a remote IPFS pinning service using Helia",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf ./dist*",
    "build": "vite build --config ./vite.config-publisher.js && vite build --config ./vite.config-resolver.js",
    "bootstrapper": "node bootstrapper.js",
    "pinning-service": "node pinning-service.js",
    "publisher": "vite --config ./vite.config-publisher.js",
    "resolver": "vite --config ./vite.config-resolver.js",
    "test": "npm run build && test-browser-example test"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@helia/pinning-service-api-server": "^2.0.0",
    "@helia/remote-pinning": "^3.0.0",
    "@ipshipyard/libp2p-inspector-metrics": "^2.0.0",
    "@libp2p/bootstrap": "^12.0.16",
    "@libp2p/circuit-relay-v2": "^4.2.0",
    "@libp2p/crypto": "^5.1.15",
    "@libp2p/identify": "^4.1.0",
    "@libp2p/kad-dht": "^16.2.0",
    "@libp2p/ping": "^3.1.0",
    "@libp2p/tcp": "^11.0.15",
    "@libp2p/websockets": "^10.1.8",
    "helia": "^6.1.2",
    "it-drain": "^3.0.12",
    "libp2p": "^3.2.0",
    "multiformats": "^13.4.2",
    "uint8arrays": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.37.1",
    "@vitejs/plugin-react": "^4.0.4",
    "rimraf": "^6.0.1",
    "test-ipfs-example": "^1.3.3",
    "vite": "^6.0.9"
  }
}
